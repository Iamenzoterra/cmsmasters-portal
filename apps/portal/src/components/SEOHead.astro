---
interface Props {
  title: string
  description?: string
  price?: number
  rating?: number
  name?: string
  slug: string
  ogImage?: string
}

const { title, description, price, rating, name, slug, ogImage } = Astro.props
const canonicalURL = new URL(`/themes/${slug}`, Astro.site)

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: name || title,
  description: description || '',
  ...(price ? { offers: { '@type': 'Offer', price: String(price), priceCurrency: 'USD' } } : {}),
  ...(rating ? { aggregateRating: { '@type': 'AggregateRating', ratingValue: String(rating), bestRating: '5' } } : {}),
  url: canonicalURL.href,
}
---
<meta name="description" content={description || ''} />
<link rel="canonical" href={canonicalURL.href} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description || ''} />
<meta property="og:type" content="product" />
<meta property="og:url" content={canonicalURL.href} />
{ogImage && <meta property="og:image" content={ogImage} />}

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
