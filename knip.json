{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignoreBinaries": ["tsx", "eslint", "jest"],
  "ignoreDependencies": ["jscpd"],
  "ignoreWorkspaces": ["packages/email"],
  "workspaces": {
    ".": {
      "ignore": ["**/*.d.ts"]
    },
    "apps/command-center": {
      "entry": ["app/**/page.tsx", "cli/**/*.ts", "tailwind.config.ts"],
      "project": ["**/*.{ts,tsx}"]
    },
    "packages/ui": {
      "entry": ["src/portal/animate-utils.js", "src/portal/portal-blocks.css", "src/theme/tokens.css"]
    }
  }
}
