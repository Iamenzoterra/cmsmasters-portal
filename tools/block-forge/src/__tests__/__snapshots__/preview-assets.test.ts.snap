 * @param {NodeList|HTMLElement[]} targets
 * @param {{ strength?: number, resetOnLeave?: boolean }} [opts]
 */
export function trackMouse(container, targets, opts = {}) {
  const { strength = 20, resetOnLeave = true } = opts
