  let raf = 0

  function tick() {
    velocity = (velocity + (to - value) * stiffness) * damping
    value += velocity
    callback(value)
    if (Math.abs(velocity) > 0.01 || Math.abs(to - value) > 0.01) {
      raf = requestAnimationFrame(tick)
