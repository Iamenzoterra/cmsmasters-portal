{
  "name": "cmsmasters-portal",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "cc:scan": "npx tsx apps/command-center/cli/scan.ts",
    "cc:report": "npx tsx apps/command-center/cli/report.ts",
    "quality": "bash quality-check.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dependency-cruiser": "^17.3.9",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "jscpd": "^4.0.8",
    "knip": "^5.86.0",
    "turbo": "latest",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.0"
  }
}
